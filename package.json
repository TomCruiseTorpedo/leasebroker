{
  "name": "leasebroker",
  "version": "0.3.0",
  "description": "Local-first broker that issues time-bounded, narrowly-scoped capability leases to AI agents and MCP servers, instead of standing permissions.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TomCruiseTorpedo/leasebroker.git"
  },
  "bugs": {
    "url": "https://github.com/TomCruiseTorpedo/leasebroker/issues"
  },
  "homepage": "https://github.com/TomCruiseTorpedo/leasebroker#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "agent",
    "llm",
    "capability",
    "least-privilege",
    "security",
    "lease",
    "authorization",
    "proxy"
  ],
  "type": "module",
  "license": "Apache-2.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "leasebroker": "dist/cli/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli/index.js",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "bun ./scripts/demo.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@noble/ed25519": "^3.1.0",
    "@opentelemetry/api-logs": "^0.220.0",
    "minimatch": "^10.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
